# Lumu MSSP Console Authentication
LUMU_EMAIL=your_email@example.com
LUMU_PASSWORD=your_password
LUMU_MSSP_UUID=your_mssp_uuid_here

# Lumu API Endpoints (Defaults)
# LUMU_API_BASE_URL=https://managed.lumu.io
# LUMU_DEFENDER_URL=https://defender.lumu.io
# LUMU_PORTAL_URL=https://portal.lumu.io

# Multi-tenant mode:
# The service discovers supervised customers from MSSP and fetches each tenant Defender key dynamically.

# Orchestration Configuration
POLLING_INTERVAL_MINUTES=5

# Persistence Configuration
# ALERT_STATE_FILE=data/alerts.json

# Kafka Configuration (active sink)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=lumu-incident-handler
KAFKA_DELIVERY_TIMEOUT_SECONDS=15
KAFKA_FLUSH_TIMEOUT_SECONDS=10
PAYLOAD_TIMEZONE=America/Sao_Paulo
# Debug: when true, forces lumu.event_type to "test"
EVENT_TYPE_TEST_MODE=False

# SSL Configuration
VERIFY_SSL=False

# Resilience Configuration
LUMU_MAX_RETRIES=5
LUMU_INITIAL_BACKOFF=1.0
