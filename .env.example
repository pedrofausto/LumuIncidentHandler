# Lumu MSSP Console Authentication
LUMU_EMAIL=your_email@example.com
LUMU_PASSWORD=your_password
LUMU_MSSP_UUID=your_mssp_uuid_here

# Lumu API Endpoints (Defaults)
# LUMU_API_BASE_URL=https://managed.lumu.io
# LUMU_DEFENDER_URL=https://defender.lumu.io
# LUMU_PORTAL_URL=https://portal.lumu.io

# Lumu Defender API Key (used as ?key= param for incident endpoints)
LUMU_DEFENDER_KEY=your_defender_api_key_here

# Customer to monitor (single tenant)
CUSTOMER_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CUSTOMER_NAME=My Customer Company

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=your_app_password_here
SMTP_FROM_EMAIL=alerts@example.com

# Alerting Destination
ALERT_TO_EMAIL=soc@example.com

# Orchestration Configuration
POLLING_INTERVAL_MINUTES=5

# Persistence Configuration
# ALERT_STATE_FILE=data/alerts.json
