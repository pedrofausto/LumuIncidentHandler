# Lumu MSSP Console Authentication
LUMU_EMAIL=your_email@example.com
LUMU_PASSWORD=your_password
LUMU_MSSP_UUID=your_mssp_uuid_here

# Lumu API Endpoints (Defaults)
# LUMU_API_BASE_URL=https://managed.lumu.io
# LUMU_DEFENDER_URL=https://defender.lumu.io
# LUMU_PORTAL_URL=https://portal.lumu.io

# Multi-tenant mode:
# The service discovers supervised customers from MSSP and fetches each tenant Defender key dynamically.

# Orchestration Configuration
POLLING_INTERVAL_MINUTES=5
LUMU_OPEN_STATE_RECONCILIATION_MINUTES=15
LUMU_OPEN_STATE_JITTER_SECONDS=120
LUMU_OPEN_STATE_FAILURE_BACKOFF_MINUTES=30
LUMU_OPEN_STATE_MAX_BACKOFF_MINUTES=360
LUMU_OPEN_STATE_SYNC_ON_STARTUP=True
LUMU_TENANT_CONCURRENCY_CAP=3
LUMU_TENANT_CYCLE_JITTER_MAX_SECONDS=5
LUMU_DEFENDER_BUDGET_ENFORCE=True
LUMU_DEFENDER_BUDGET_MINUTE_LIMIT=35
LUMU_DEFENDER_BUDGET_DAY_LIMIT=8000
LUMU_JOURNAL_ITEMS_PER_PAGE=100
LUMU_JOURNAL_DELAY_TIME_SECONDS=15
LUMU_JOURNAL_MAX_PAGES_PER_CYCLE=2
LUMU_DEFENDER_USE_MAX_ITEMS_PARAM=True
LUMU_DEFENDER_MAX_ITEMS_PARAM=500
LUMU_DEFENDER_GLOBAL_MIN_INTERVAL_SECONDS=2.5
LUMU_DEFENDER_JOURNAL_MIN_INTERVAL_SECONDS=5.0
LUMU_DEFENDER_JOURNAL_RETRY_AFTER_FLOOR_SECONDS=30.0
LUMU_DEFENDER_ENDPOINT_COOLDOWN_DEFAULT_SECONDS=60
LUMU_DEFENDER_JOURNAL_CIRCUIT_BREAKER_ENABLED=True
LUMU_DEFENDER_JOURNAL_CIRCUIT_BREAKER_THRESHOLD=3
LUMU_DEFENDER_JOURNAL_CIRCUIT_BREAKER_OPEN_SECONDS=600
LUMU_DEFENDER_JOURNAL_CIRCUIT_BREAKER_HALF_OPEN_PROBE_SECONDS=60
LUMU_DEFENDER_RETRY_RESPECT_RETRY_AFTER=True

# Persistence Configuration
# ALERT_STATE_FILE=data/alerts.json

# Kafka Configuration (active sink)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=lumu-incident-handler
KAFKA_DELIVERY_TIMEOUT_SECONDS=15
KAFKA_FLUSH_TIMEOUT_SECONDS=10
PAYLOAD_TIMEZONE=America/Sao_Paulo
# Debug: when true, forces lumu.event_type to "test"
EVENT_TYPE_TEST_MODE=False

# SSL Configuration
VERIFY_SSL=False

# Resilience Configuration
LUMU_MAX_RETRIES=5
LUMU_INITIAL_BACKOFF=1.0
